---
interface Props {
  col: number;     // col-span 1..12
  row?: number;    // row-span 1..3 (default 1)
  feature?: boolean; // tinted card for visual emphasis
  image?: boolean;   // remove inner padding (cell is dominated by an image)
  class?: string;
}
const {
  col,
  row = 1,
  feature = false,
  image = false,
  class: extra = "",
} = Astro.props;

const innerCls = [
  "card-bezel-inner",
  feature ? "feature" : "",
  image ? "!p-0 overflow-hidden" : "",
].filter(Boolean).join(" ");

const style = `grid-column: span ${col} / span ${col}; grid-row: span ${row} / span ${row};`;
---

<div class={`card-bezel ${extra}`.trim()} style={style}>
  <div class={innerCls}>
    <slot />
  </div>
</div>
