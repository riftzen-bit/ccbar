---
import "../styles/global.css";
import Masthead from "../components/Masthead.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ccbar — meter Claude Code and OpenAI Codex usage",
  description = "A desktop app that meters your Claude Code and OpenAI Codex usage from disk. Local-only. No accounts. Live 5h and weekly windows for both providers.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body class="relative min-h-screen overflow-x-hidden">
    <div class="relative z-[1] mx-auto w-full max-w-[1280px] px-5 md:px-8 lg:px-10">
      <Masthead />
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      if ("fonts" in document) {
        document.fonts.ready.then(() => {
          const w = window as any;
          if (w.ScrollTrigger?.refresh) w.ScrollTrigger.refresh();
        });
      }
    </script>
  </body>
</html>
